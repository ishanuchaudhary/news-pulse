# ── Scraper .env ──────────────────────────────────────────────────────────────
# Loaded automatically if you run:  python-dotenv  or export manually.

# Path where SQLite DB is written (must match backend DB_PATH)
DB_PATH=news_pulse.db

# Cosine similarity threshold for grouping (0.0–1.0, lower = bigger clusters)
SIM_THRESHOLD=0.20

# Minimum articles per cluster (singletons are dropped below this)
MIN_CLUSTER=2

# ── Backend .env ──────────────────────────────────────────────────────────────
# Copy this to .env and fill in values. Never commit the real .env file.

PORT=4000

# Absolute path to the SQLite DB written by the Python scraper
DB_PATH=/absolute/path/to/news-pulse/scraper/news_pulse.db

# Python binary (use "python" on Windows)
PYTHON_BIN=python3

# Frontend URL for CORS (set to your Vercel URL in production)
FRONTEND_URL=http://localhost:3000
